# Local Docker Compose Postgres (see docker-compose.yml):
# DATABASE_URL=postgresql://bulbau:bulbau_dev_only@localhost:5432/bulbau
#
# Or a personal Neon branch (recommended — see docs/TECHSPEC.md §10.1),
# using the POOLED connection string (hostname contains "-pooler"):
DATABASE_URL=postgresql://user:password@ep-example-pooler.eu-central-1.aws.neon.tech/dbname?sslmode=require&channel_binding=require
#
# Migrations only: DDL must use the DIRECT (unpooled) URL — the same host
# WITHOUT "-pooler" — because Neon's PgBouncer pooler (transaction pooling)
# breaks schema changes. For local dev you rarely need this (push mode keeps
# your dev DB in sync); it matters for `npm run migrate` against a real stage.
# CI uses the STAGING_DATABASE_URL_UNPOOLED GitHub secret for this. See README
# "Database migrations".

# Generate with: openssl rand -base64 32
PAYLOAD_SECRET=YOUR_SECRET_HERE

# TOTP (2FA) secret encryption + step-up cookie signing — a separate secret
# from PAYLOAD_SECRET on purpose (key separation). Generate the same way:
# openssl rand -base64 32
TOTP_ENCRYPTION_KEY=YOUR_TOTP_KEY_HERE

# Rate limiting / lockout for TOTP verification attempts (Upstash Redis —
# see docs/TECHSPEC.md §3). Required in staging/production. If left unset,
# src/lib/totp/rateLimit.ts falls back to an in-memory limiter — fine for
# local dev and CI (same idea as S3Mock standing in for real S3 below), but
# NOT safe for a real multi-instance deployment. Create a free database at
# https://console.upstash.com/ and copy its REST URL/token:
# UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

# Media uploads use @payloadcms/storage-s3 — there is no local-disk fallback
# (Lambda's filesystem is read-only outside /tmp, so local-disk storage was
# never an option). Point S3_BUCKET at any bucket you can reach (a personal
# AWS bucket, or a bucket in a shared dev account) for real-AWS local dev:
S3_BUCKET=your-dev-bucket-name
AWS_REGION=eu-central-1

# Or, to avoid needing real AWS credentials at all for local dev, run the
# S3Mock container (see docker-compose.yml) and point at it instead — leave
# S3_BUCKET as below to match its pre-created bucket:
# S3_BUCKET=bulbau-dev
# S3_ENDPOINT=http://localhost:9090
# S3_ACCESS_KEY_ID=test
# S3_SECRET_ACCESS_KEY=test

# ── Public site (Phase 2) ────────────────────────────────────────────────────
# Canonical origin used for canonical tags, hreflang alternates, Open Graph URLs
# and the sitemap (src/lib/seo.ts). Locally you can leave this unset (defaults to
# the production domain). On a deployed stage it's an SST secret (SiteUrl); set it
# to that stage's real origin (e.g. the CloudFront URL on staging) for accurate
# canonicals. NEXT_PUBLIC_* ⇒ inlined into the build.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
#
# Search-engine indexing gate. OFF unless explicitly 'true'. Leave unset/empty
# everywhere except the production stage at launch — this is what keeps the
# staging CloudFront URL out of search results (SST secret: AllowIndexing).
# NEXT_PUBLIC_ALLOW_INDEXING=false
