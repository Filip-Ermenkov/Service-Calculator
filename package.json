{
  "name": "bulbau-lu",
  "version": "0.1.0",
  "description": "bulbau.lu — multilingual service calculator site (Next.js + Payload CMS)",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10"
  },
  "scripts": {
    "postinstall": "sst install",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "migrate:create": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:create",
    "migrate:status": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:status",
    "migrate:fresh": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:fresh",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:int && npm run test:e2e",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "deploy:staging": "sst deploy --stage staging",
    "deploy:production": "sst deploy --stage production"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.85.2",
    "@payloadcms/next": "3.85.2",
    "@payloadcms/richtext-lexical": "3.85.2",
    "@payloadcms/storage-s3": "3.85.2",
    "@payloadcms/ui": "3.85.2",
    "@upstash/ratelimit": "2.0.8",
    "@upstash/redis": "1.38.0",
    "cross-env": "10.1.0",
    "dotenv": "16.4.7",
    "graphql": "17.0.2",
    "jose": "6.2.3",
    "next": "16.2.10",
    "next-intl": "^4.13.2",
    "otplib": "13.4.1",
    "payload": "3.85.2",
    "qrcode": "1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@eslint/compat": "2.1.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "24.12.3",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.10",
    "jsdom": "^28.0.0",
    "prettier": "^3.4.2",
    "sst": "4.17.0",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.1.6"
  }
}
