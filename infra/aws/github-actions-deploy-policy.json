{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ManageBootstrapStateBucket",
      "Effect": "Allow",
      "Action": [
        "s3:CreateBucket",
        "s3:PutBucketVersioning",
        "s3:PutBucketNotification",
        "s3:PutBucketPolicy",
        "s3:DeleteObject",
        "s3:DeleteObjectVersion",
        "s3:GetObject",
        "s3:ListBucket",
        "s3:ListBucketVersions",
        "s3:PutObject"
      ],
      "Resource": ["arn:aws:s3:::sst-state-*"]
    },
    {
      "Sid": "ManageBootstrapAssetBucket",
      "Effect": "Allow",
      "Action": [
        "s3:CreateBucket",
        "s3:PutBucketVersioning",
        "s3:PutBucketNotification",
        "s3:PutBucketPolicy",
        "s3:DeleteObject",
        "s3:GetObject",
        "s3:ListBucket",
        "s3:PutObject"
      ],
      "Resource": ["arn:aws:s3:::sst-asset-*"]
    },
    {
      "Sid": "ManageBootstrapECRRepo",
      "Effect": "Allow",
      "Action": ["ecr:CreateRepository", "ecr:DescribeRepositories"],
      "Resource": ["arn:aws:ecr:eu-central-1:176971015975:repository/sst-asset"]
    },
    {
      "Sid": "ManageBootstrapSSMParameter",
      "Effect": "Allow",
      "Action": ["ssm:GetParameters", "ssm:PutParameter"],
      "Resource": [
        "arn:aws:ssm:eu-central-1:176971015975:parameter/sst/passphrase/*",
        "arn:aws:ssm:eu-central-1:176971015975:parameter/sst/bootstrap"
      ]
    },
    {
      "Sid": "ManageSecrets",
      "Effect": "Allow",
      "Action": [
        "ssm:DeleteParameter",
        "ssm:GetParameter",
        "ssm:GetParameters",
        "ssm:GetParametersByPath",
        "ssm:PutParameter",
        "ssm:AddTagsToResource",
        "ssm:ListTagsForResource"
      ],
      "Resource": ["arn:aws:ssm:eu-central-1:176971015975:parameter/sst/*"]
    },
    {
      "Sid": "DeploymentsScopedToRegion",
      "Effect": "Allow",
      "Action": ["*"],
      "Resource": ["*"],
      "Condition": {
        "StringEquals": { "aws:RequestedRegion": "eu-central-1" }
      }
    },
    {
      "Sid": "ManageCloudFront",
      "Effect": "Allow",
      "Action": "cloudfront:*",
      "Resource": "*"
    },
    {
      "Sid": "ExplicitDenyHighRiskActions",
      "Effect": "Deny",
      "Action": [
        "iam:CreateUser",
        "iam:CreateAccessKey",
        "iam:AttachUserPolicy",
        "iam:PutUserPolicy",
        "iam:CreateLoginProfile",
        "iam:UpdateAssumeRolePolicy",
        "iam:DeleteAccountPasswordPolicy",
        "iam:UpdateAccountPasswordPolicy",
        "organizations:*",
        "account:*",
        "aws-portal:*"
      ],
      "Resource": "*"
    }
  ]
}
